# ───────────────────────────────────────────────────────────────
# TravelCRM production env — copy to infra/docker/.env on the VPS.
# NEVER commit the real .env. Generate strong secrets:
#   openssl rand -hex 32   (for JWT/refresh/encryption)
#   openssl rand -base64 24 (for DB / S3 passwords)
# ───────────────────────────────────────────────────────────────

# Public URL of the deployed app (sub-domain OR IP subpath).
# Subpath example:  http://187.127.185.243/travelcrm
# Subdomain example: https://travelcrm.YOURDOMAIN.com
PUBLIC_BASE_URL=http://187.127.185.243/travelcrm

# Next.js + edge nginx subpath (leave empty for subdomain/root deploy).
BASE_PATH=/travelcrm

# Edge proxy binds to 127.0.0.1:<EDGE_PORT> ONLY (host nginx proxies here).
# Pick a free localhost port that doesn't collide with existing projects.
EDGE_PORT=8090

# Internal edge nginx config (subpath vs root).
NGINX_CONF=../nginx/nginx.subpath.conf

# ── App ──
NODE_ENV=production
PORT=4000
APP_BASE_URL=http://187.127.185.243/travelcrm
API_BASE_URL=http://187.127.185.243/travelcrm
CORS_ORIGINS=http://187.127.185.243

# ── Database (internal to the compose network) ──
POSTGRES_USER=travelcrm
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=travelcrm
# Privileged role: migrations + system/cross-tenant ops.
DATABASE_URL=postgresql://travelcrm:CHANGE_ME_db_password@postgres:5432/travelcrm?schema=public
# RLS-enforced app role for request queries (create via prisma/roles.sql).
# Strongly recommended in production for DB-level tenant isolation.
APP_DATABASE_URL=postgresql://travelcrm_app:CHANGE_ME_app_password@postgres:5432/travelcrm?schema=public

# ── Redis (internal) ──
REDIS_URL=redis://redis:6379

# ── Auth secrets ──
JWT_ACCESS_SECRET=CHANGE_ME_64_hex
JWT_REFRESH_SECRET=CHANGE_ME_64_hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
ENCRYPTION_KEY=CHANGE_ME_64_hex

# ── Storage (internal MinIO) ──
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=travelcrm
S3_ACCESS_KEY=travelcrm
S3_SECRET_KEY=CHANGE_ME_s3_secret
S3_FORCE_PATH_STYLE=true

# ── First-login bootstrap (created by the `migrate` step) ──
BOOTSTRAP_TENANT_SLUG=demo
BOOTSTRAP_TENANT_NAME=Demo Travel Co.
BOOTSTRAP_ADMIN_EMAIL=admin@YOURDOMAIN.com
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_password
