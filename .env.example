# ─────────────────────────────────────────────────────────────
# TravelOS AI — environment variables (template)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Hostinger API token — used by the hostinger-* MCP servers in .mcp.json
# Generate at: Hostinger panel → Account → API tokens
HOSTINGER_API_TOKEN=your-hostinger-api-token-here

# Supabase
# The supabase MCP server (.mcp.json) authenticates via OAuth (`claude /mcp`),
# not via a key here. Application DB access uses the values below.
SUPABASE_PROJECT_REF=bbwnwrgtiwpfewswjfhd
# SUPABASE_URL=https://bbwnwrgtiwpfewswjfhd.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# DATABASE_URL=
