{
  "name": "travelos-ai",
  "version": "0.0.0",
  "private": true,
  "description": "TravelOS AI — AI-powered Tour & Travel CRM platform (monorepo)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @travelos/api db:migrate",
    "db:seed": "pnpm --filter @travelos/api db:seed",
    "db:generate": "pnpm --filter @travelos/api db:generate",
    "dev:up": "docker compose -f infra/docker/docker-compose.dev.yml up -d",
    "dev:down": "docker compose -f infra/docker/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "esbuild",
      "msgpackr-extract"
    ],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
