// TravelOS AI — Prisma schema (Phase 0: Platform Core)
// See docs/architecture/02-database-schema.md for the full target model.
// Multi-tenant: every business table carries tenant_id; PostgreSQL RLS policies
// (apply-rls.mjs) enforce isolation in addition to app-layer scoping.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum TenantStatus {
  active
  trial
  suspended
  cancelled
}

enum TenantPlan {
  starter
  growth
  enterprise
}

enum UserStatus {
  active
  invited
  disabled
}

enum TeamType {
  sales
  operations
  accounts
  vendor
}

enum OtpChannel {
  sms
  whatsapp
  email
}

enum OtpPurpose {
  login
  verify
}

enum AuditAction {
  created
  updated
  deleted
  assigned
  transferred
  status_changed
  payment_updated
  quotation_updated
  login
  logout
  export
  permission_change
}

enum AuditActorType {
  user
  customer
  system
  integration
}

enum LeadStage {
  new
  contacted
  interested
  quotation_sent
  negotiation
  follow_up
  confirmed
  lost
  cancelled
}

enum LeadStatus {
  open
  won
  lost
}

enum LeadPriority {
  low
  medium
  high
  hot
}

enum LeadSourceType {
  website
  landing_page
  contact_form
  manual
  whatsapp
  facebook_ads
  instagram_ads
  google_forms
  referral
  import
}

enum AssignmentStrategy {
  round_robin
  team
  destination
  load_balanced
  manual
}

enum ActivityType {
  stage_change
  note
  task
  call
  whatsapp
  email
  quotation
  payment
  assignment
  ai_insight
  system
}

enum TaskType {
  call
  follow_up
  email
  whatsapp
  meeting
  custom
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum DedupeMatchType {
  phone
  email
  fuzzy
}

enum QuotationStatus {
  draft
  sent
  viewed
  accepted
  rejected
  expired
}

// ─────────────────────────────── Models ──────────────────────────────

model Tenant {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String       @unique
  customDomain String?      @unique @map("custom_domain")
  status       TenantStatus @default(trial)
  plan         TenantPlan   @default(starter)
  settings     Json         @default("{}")
  billingEmail String?      @map("billing_email")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  users         User[]
  teams         Team[]
  roles         Role[]
  userRoles     UserRole[]
  sessions      Session[]
  loginHistory  LoginHistory[]
  otpChallenges OtpChallenge[]
  auditLogs     AuditLog[]
  notifications Notification[]
  files         File[]

  leadSources     LeadSource[]
  leads           Lead[]
  leadActivities  LeadActivity[]
  notes           Note[]
  tasks           Task[]
  tags            Tag[]
  leadTags        LeadTag[]
  lostReasons     LostReason[]
  assignmentRules AssignmentRule[]
  dedupeMatches   LeadDedupeMatch[]
  attachments     Attachment[]
  quotations      Quotation[]
  quotationVersions QuotationVersion[]

  @@map("tenant")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  email        String     @db.Citext
  phone        String?
  passwordHash String?    @map("password_hash")
  fullName     String     @map("full_name")
  avatarUrl    String?    @map("avatar_url")
  status       UserStatus @default(invited)
  is2faEnabled Boolean    @default(false) @map("is_2fa_enabled")
  totpSecret   String?    @map("totp_secret_enc")
  lastLoginAt  DateTime?  @map("last_login_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles    UserRole[]
  teamMembers  TeamMember[]
  sessions     Session[]
  managedTeams Team[]         @relation("TeamManager")
  loginHistory LoginHistory[]
  auditLogs    AuditLog[]
  notifications Notification[]

  assignedLeads Lead[]         @relation("LeadAssignee")
  createdLeads  Lead[]         @relation("LeadCreator")
  notes         Note[]
  assignedTasks Task[]         @relation("TaskAssignee")

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("user")
}

model Team {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  type          TeamType
  managerUserId String?  @map("manager_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager User?        @relation("TeamManager", fields: [managerUserId], references: [id])
  members TeamMember[]
  userRoles UserRole[]
  leads   Lead[]       @relation("LeadTeam")

  @@index([tenantId, type])
  @@map("team")
}

model TeamMember {
  teamId     String   @map("team_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleInTeam String?  @map("role_in_team")
  createdAt  DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_member")
}

// Roles: tenantId NULL = system role (shared catalogue), else tenant custom role.
model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid
  key         String
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant          Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, key])
  @@map("role")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique // e.g. "lead.create"
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permission")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRole {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String  @map("tenant_id") @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  roleId      String  @map("role_id") @db.Uuid
  scopeTeamId String? @map("scope_team_id") @db.Uuid

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scopeTeam Team?  @relation(fields: [scopeTeamId], references: [id])

  @@unique([userId, roleId, scopeTeamId])
  @@index([tenantId, userId])
  @@map("user_role")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  device           String?
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@index([refreshTokenHash])
  @@map("session")
}

model LoginHistory {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  email         String
  success       Boolean
  failureReason String?  @map("failure_reason")
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, email])
  @@map("login_history")
}

model OtpChallenge {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  identityRef  String     @map("identity_ref") // phone or email
  channel      OtpChannel
  codeHash     String     @map("code_hash")
  purpose      OtpPurpose @default(login)
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  attempts     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, identityRef])
  @@map("otp_challenge")
}

model AuditLog {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  actorUserId  String?        @map("actor_user_id") @db.Uuid
  actorType    AuditActorType @default(user) @map("actor_type")
  action       AuditAction
  resourceType String         @map("resource_type")
  resourceId   String?        @map("resource_id") @db.Uuid
  before       Json?
  after        Json?
  ipAddress    String?        @map("ip_address")
  userAgent    String?        @map("user_agent")
  createdAt    DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id])

  @@index([tenantId, resourceType, resourceId, createdAt])
  @@map("audit_log")
}

model Notification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  type       String
  title      String
  body       String?
  refTable   String?  @map("ref_table")
  refId      String?  @map("ref_id") @db.Uuid
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
  @@map("notification")
}

model File {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  bucket             String
  objectKey          String   @map("object_key")
  filename           String
  contentType        String   @map("content_type")
  sizeBytes          BigInt   @map("size_bytes")
  checksum           String?
  category           String
  ownerResourceType  String?  @map("owner_resource_type")
  ownerResourceId    String?  @map("owner_resource_id") @db.Uuid
  isPublic           Boolean  @default(false) @map("is_public")
  createdBy          String?  @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, category])
  @@map("file")
}

// ───────────────────────── Leads domain (Phase 1) ─────────────────────────

model LeadSource {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  type      LeadSourceType
  name      String
  config    Json           @default("{}")
  secret    String?        // shared secret for public capture / webhook verification
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@index([tenantId, type])
  @@map("lead_source")
}

model Lead {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  sourceId        String?       @map("source_id") @db.Uuid
  referenceCode   String        @map("reference_code")
  stage           LeadStage     @default(new)
  status          LeadStatus    @default(open)
  name            String
  email           String?       @db.Citext
  phone           String?
  altPhone        String?       @map("alt_phone")
  destination     String?
  travelDate      DateTime?     @map("travel_date") @db.Date
  returnDate      DateTime?     @map("return_date") @db.Date
  adults          Int           @default(1)
  children        Int           @default(0)
  budgetAmount    Decimal?      @map("budget_amount") @db.Decimal(14, 2)
  budgetCurrency  String        @default("INR") @map("budget_currency") @db.Char(3)
  hotelPreference String?       @map("hotel_preference")
  flightRequired  Boolean?      @map("flight_required")
  specialRequests String?       @map("special_requests")
  assignedUserId  String?       @map("assigned_user_id") @db.Uuid
  assignedTeamId  String?       @map("assigned_team_id") @db.Uuid
  priority        LeadPriority  @default(medium)
  score           Int?
  lostReasonId    String?       @map("lost_reason_id") @db.Uuid
  dedupeHash      String?       @map("dedupe_hash")
  metadata        Json          @default("{}")
  createdBy       String?       @map("created_by") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  source       LeadSource? @relation(fields: [sourceId], references: [id])
  assignedUser User?       @relation("LeadAssignee", fields: [assignedUserId], references: [id])
  assignedTeam Team?       @relation("LeadTeam", fields: [assignedTeamId], references: [id])
  creator      User?       @relation("LeadCreator", fields: [createdBy], references: [id])
  lostReason   LostReason? @relation(fields: [lostReasonId], references: [id])

  activities     LeadActivity[]
  notes          Note[]
  tasks          Task[]
  leadTags       LeadTag[]
  attachments    Attachment[]
  dedupeAsLead   LeadDedupeMatch[] @relation("DedupeLead")
  dedupeAsDup    LeadDedupeMatch[] @relation("DedupeDuplicateOf")
  quotations     Quotation[]

  @@unique([tenantId, referenceCode])
  @@index([tenantId, stage])
  @@index([tenantId, assignedUserId])
  @@index([tenantId, phone])
  @@index([tenantId, dedupeHash])
  @@index([tenantId, destination])
  @@index([tenantId, travelDate])
  @@map("lead")
}

model LeadActivity {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  leadId     String       @map("lead_id") @db.Uuid
  type       ActivityType
  title      String
  body       String?
  refTable   String?      @map("ref_table")
  refId      String?      @map("ref_id") @db.Uuid
  actorUserId String?     @map("actor_user_id") @db.Uuid
  metadata   Json         @default("{}")
  createdAt  DateTime     @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId, createdAt])
  @@map("lead_activity")
}

model Note {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  leadId       String   @map("lead_id") @db.Uuid
  authorUserId String?  @map("author_user_id") @db.Uuid
  body         String
  isPinned     Boolean  @default(false) @map("is_pinned")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorUserId], references: [id])

  @@index([tenantId, leadId])
  @@map("note")
}

model Task {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String     @map("tenant_id") @db.Uuid
  leadId         String?    @map("lead_id") @db.Uuid
  title          String
  description    String?
  type           TaskType   @default(follow_up)
  dueAt          DateTime?  @map("due_at")
  remindAt       DateTime?  @map("remind_at")
  status         TaskStatus @default(pending)
  assigneeUserId String     @map("assignee_user_id") @db.Uuid
  completedAt    DateTime?  @map("completed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee User   @relation("TaskAssignee", fields: [assigneeUserId], references: [id])

  @@index([tenantId, assigneeUserId, dueAt])
  @@index([tenantId, status, remindAt])
  @@map("task")
}

model Tag {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid
  name     String
  color    String @default("#64748b")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadTags LeadTag[]

  @@unique([tenantId, name])
  @@map("tag")
}

model LeadTag {
  tenantId String @map("tenant_id") @db.Uuid
  leadId   String @map("lead_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@map("lead_tag")
}

model LostReason {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId String  @map("tenant_id") @db.Uuid
  label    String
  category String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@unique([tenantId, label])
  @@map("lost_reason")
}

model AssignmentRule {
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  name         String
  strategy     AssignmentStrategy
  conditions   Json               @default("{}")
  targetTeamId String?            @map("target_team_id") @db.Uuid
  targetUserIds String[]          @map("target_user_ids") @db.Uuid
  priority     Int                @default(100)
  isActive     Boolean            @default(true) @map("is_active")
  createdAt    DateTime           @default(now()) @map("created_at")

  tenant Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  state  AssignmentRuleState?

  @@index([tenantId, priority])
  @@map("assignment_rule")
}

model AssignmentRuleState {
  ruleId     String   @id @map("rule_id") @db.Uuid
  lastUserId String?  @map("last_user_id") @db.Uuid
  updatedAt  DateTime @updatedAt @map("updated_at")

  rule AssignmentRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("assignment_rule_state")
}

model LeadDedupeMatch {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  leadId           String          @map("lead_id") @db.Uuid
  duplicateOfLeadId String         @map("duplicate_of_lead_id") @db.Uuid
  matchType        DedupeMatchType @map("match_type")
  confidence       Decimal         @default(1.0) @db.Decimal(4, 3)
  resolved         Boolean         @default(false)
  resolvedBy       String?         @map("resolved_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead        Lead   @relation("DedupeLead", fields: [leadId], references: [id], onDelete: Cascade)
  duplicateOf Lead   @relation("DedupeDuplicateOf", fields: [duplicateOfLeadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@map("lead_dedupe_match")
}

model Attachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  fileId     String   @map("file_id") @db.Uuid
  label      String?
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId])
  @@map("attachment")
}

// ─────────────────────── Quotations (Phase 2, Module 6) ───────────────────────

model Quotation {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  leadId           String          @map("lead_id") @db.Uuid
  referenceCode    String          @map("reference_code")
  title            String
  currentVersionId String?         @map("current_version_id") @db.Uuid
  revisionCount    Int             @default(0) @map("revision_count")
  status           QuotationStatus @default(draft)
  sentAt           DateTime?       @map("sent_at")
  viewedAt         DateTime?       @map("viewed_at")
  decidedAt        DateTime?       @map("decided_at")
  validUntil       DateTime?       @map("valid_until") @db.Date
  rejectionReason  String?         @map("rejection_reason")
  totalAmount      Decimal         @default(0) @map("total_amount") @db.Decimal(14, 2)
  currency         String          @default("INR") @db.Char(3)
  createdBy        String?         @map("created_by") @db.Uuid
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  versions QuotationVersion[]

  @@unique([tenantId, referenceCode])
  @@index([tenantId, leadId])
  @@index([tenantId, status])
  @@index([tenantId, validUntil])
  @@map("quotation")
}

model QuotationVersion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  quotationId String   @map("quotation_id") @db.Uuid
  versionNo   Int      @map("version_no")
  lineItems   Json     @default("[]") @map("line_items")
  subtotal    Decimal  @default(0) @db.Decimal(14, 2)
  tax         Decimal  @default(0) @db.Decimal(14, 2)
  discount    Decimal  @default(0) @db.Decimal(14, 2)
  total       Decimal  @default(0) @db.Decimal(14, 2)
  currency    String   @default("INR") @db.Char(3)
  notes       String?
  pdfFileId   String?  @map("pdf_file_id") @db.Uuid
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@unique([quotationId, versionNo])
  @@map("quotation_version")
}
