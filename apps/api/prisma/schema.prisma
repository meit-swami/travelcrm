// ──────────────── Customer Portal (Phase 4, Module 12) ────────────────

model PortalIdentity {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  leadId      String?  @map("lead_id") @db.Uuid
  phone       String
  email       String?  @db.Citext
  lastLoginAt DateTime? @map("last_login_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grants PortalAccessGrant[]

  @@unique([tenantId, phone])
  @@map("portal_identity")
}

model PortalAccessGrant {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  portalIdentityId String             @map("portal_identity_id") @db.Uuid
  resourceType     PortalResourceType @map("resource_type")
  resourceId       String             @map("resource_id") @db.Uuid
  canView          Boolean            @default(true) @map("can_view")
  canDownload      Boolean            @default(false) @map("can_download")
  createdAt        DateTime           @default(now()) @map("created_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  identity PortalIdentity @relation(fields: [portalIdentityId], references: [id], onDelete: Cascade)

  @@index([tenantId, portalIdentityId])
  @@map("portal_access_grant")
}

// ─────────────────── Email automation (Phase 2, Module 14) ───────────────────

model EmailTemplate {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  key       String
  name      String
  subject   String
  htmlBody  String   @map("html_body")
  variables Json     @default("[]")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("email_template")
}

model EmailLog {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  leadId            String?     @map("lead_id") @db.Uuid
  templateKey       String?     @map("template_key")
  toEmail           String      @map("to_email")
  subject           String
  status            EmailStatus @default(queued)
  providerMessageId String?     @map("provider_message_id")
  error             String?
  sentAt            DateTime?   @map("sent_at")
  createdAt         DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("email_log")
}

model Automation {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String            @map("tenant_id") @db.Uuid
  triggerEvent AutomationTrigger @map("trigger_event")
  channel      String            @default("email")
  templateKey  String            @map("template_key")
  delayMinutes Int               @default(0) @map("delay_minutes")
  conditions   Json              @default("{}")
  isActive     Boolean           @default(true) @map("is_active")
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, triggerEvent])
  @@map("automation")
}
