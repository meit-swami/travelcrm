  email
  sms
}

enum ConversationStatus {
  open
  closed
  archived
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageContentType {
  text
  image
  audio
  video
  document
  location
  template
}

enum MessageStatus {
  queued
  sent
  delivered
  read
  failed
}

enum IntegrationEventStatus {
  received
  processed
  failed
}

enum ItinerarySource {
  imported
  built
}

enum OpsStage {
  confirmed
  hotel_procurement
  transport_procurement
  voucher_generation
  final_itinerary
  delivered
  completed
  cancelled
}

enum OperationTaskStatus {
  pending
  in_progress
  blocked
  done
}

enum VendorType {
  hotel
  transport
  activity
  other
}

enum VendorStatus {
  active
  inactive
  blacklisted
}

enum VehicleType {
  taxi
  tempo_traveller
  coach
  other
}

enum HotelBookingStatus {
  requested
  quoted
  confirmed
  cancelled
}

enum TransportBookingStatus {
  requested
  confirmed
  cancelled
}

enum VoucherType {
  customer
  hotel
  transport
  vendor
}

enum VoucherStatus {
  draft
  generated
  sent
  void
}

enum CallProvider {
  exotel
  knowlarity
  manual
}

enum CallDirection {
  inbound
  outbound
}

enum CallStatus {
  ringing
  answered
  missed
  busy
  failed
  completed
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
