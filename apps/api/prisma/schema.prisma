// TravelOS AI — Prisma schema (Phase 0: Platform Core)
// See docs/architecture/02-database-schema.md for the full target model.
// Multi-tenant: every business table carries tenant_id; PostgreSQL RLS policies
// (apply-rls.mjs) enforce isolation in addition to app-layer scoping.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────── Enums ───────────────────────────────

enum TenantStatus {
  active
  trial
  suspended
  cancelled
}

enum TenantPlan {
  starter
  growth
  enterprise
}

enum UserStatus {
  active
  invited
  disabled
}

enum TeamType {
  sales
  operations
  accounts
  vendor
}

enum OtpChannel {
  sms
  whatsapp
  email
}

enum OtpPurpose {
  login
  verify
}

enum AuditAction {
  created
  updated
  deleted
  assigned
  transferred
  status_changed
  payment_updated
  quotation_updated
  login
  logout
  export
  permission_change
}

enum AuditActorType {
  user
  customer
  system
  integration
}

enum LeadStage {
  new
  contacted
  interested
  quotation_sent
  negotiation
  follow_up
  confirmed
  lost
  cancelled
}

enum LeadStatus {
  open
  won
  lost
}

enum LeadPriority {
  low
  medium
  high
  hot
}

enum LeadSourceType {
  website
  landing_page
  contact_form
  manual
  whatsapp
  facebook_ads
  instagram_ads
  google_forms
  referral
  import
}

enum AssignmentStrategy {
  round_robin
  team
  destination
  load_balanced
  manual
}

enum ActivityType {
  stage_change
  note
  task
  call
  whatsapp
  email
  quotation
  payment
  assignment
  ai_insight
  system
}

enum TaskType {
  call
  follow_up
  email
  whatsapp
  meeting
  custom
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum DedupeMatchType {
  phone
  email
  fuzzy
}

enum QuotationStatus {
  draft
  sent
  viewed
  accepted
  rejected
  expired
}

enum EmailStatus {
  queued
  sent
  failed
  bounced
  opened
}

enum AutomationTrigger {
  quotation_sent
  payment_received
  invoice_generated
  voucher_generated
  travel_reminder
  feedback_request
}

enum AiInsightKind {
  lead_summary
  call_summary
  chat_summary
  requirement_extract
  conversion_score
  hot_lead
  loss_reason
  quote_rejection
  mgmt_insight
}

enum ConversationChannel {
